# =====================================================================
# AskAstroBot Gateway - environment configuration
# Copy to .env on the VPS and fill in real values. Never commit .env.
# =====================================================================

# --- Supabase (database only — auth is direct Google OAuth, see below) ---
DATABASE_URL=postgres://postgres:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# --- OAuth: provider creds the gateway issues to ChatGPT ---
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_ACCESS_TOKEN_TTL=2592000
OAUTH_REFRESH_TOKEN_TTL=7776000

# --- Google OAuth (the gateway authenticates users directly with Google) ---
# Create a Web Application OAuth client at:
#   https://console.cloud.google.com/apis/credentials
# Authorised redirect URI:
#   https://api.askastrobot.com/oauth/google-callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Upgrade JWT (signed token carried from chat -> /upgrade -> Stripe) ---
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
GATEWAY_JWT_SECRET=
UPGRADE_TOKEN_TTL=900
PORTAL_TOKEN_TTL=900

# --- n8n webhook URLs (PRODUCTION paths, not /webhook-test/) ---
N8N_WEBHOOK_PRASHNA=https://app.askastrobot.com/webhook/e6971529-467e-43d6-9224-3bdce40f4b3f
N8N_WEBHOOK_HOROSCOPE=https://app.askastrobot.com/webhook/1124ff92-9662-4167-bc00-da7420919f75
N8N_WEBHOOK_CAREER=https://app.askastrobot.com/webhook/dcb303fc-1346-403a-a261-e5e1705b9aa5
N8N_WEBHOOK_MARRIAGE=https://app.askastrobot.com/webhook/35f8126a-f8ae-4bac-9211-ad0fc25e6e04

# Shared secret n8n verifies on every gateway-originated call
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
GATEWAY_SHARED_SECRET=
N8N_TIMEOUT_SECONDS=30

# --- Public URLs ---
APP_BASE_URL=https://askastrobot.com
GATEWAY_BASE_URL=https://api.askastrobot.com

# --- Misc ---
ENVIRONMENT=production
PORT=8003
LOG_LEVEL=info

# --- Observability ---
SENTRY_DSN=
